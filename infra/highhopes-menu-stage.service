[Unit]
Description=High Hopes Menu API (staging)
After=network.target

[Service]
User=root
WorkingDirectory=/home/highhopes/highhopes-menu-stage/backend
EnvironmentFile=/home/highhopes/highhopes-menu-stage/backend/.env
ExecStart=/home/highhopes/highhopes-menu-stage/backend/venv/bin/gunicorn --worker-class gthread -w 1 --threads 4 -b 127.0.0.1:5002 app:app
Restart=always
RestartSec=5
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
